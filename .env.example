# ==========================================
# Supabase 配置
# ==========================================
# 从 Supabase 项目设置中获取这些值
VITE_SUPABASE_PROJECT_ID=your_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_anon_key

# ==========================================
# 应用配置
# ==========================================
VITE_APP_NAME=萌宠到家
VITE_APP_VERSION=0.1.0
VITE_API_TIMEOUT=30000

# ==========================================
# 第三方服务 API
# ==========================================
# 高德地图 API
VITE_AMAP_API_KEY=your_amap_api_key

# 支付网关（待集成）
VITE_ALIPAY_APP_ID=your_alipay_app_id
VITE_WECHAT_PAY_MERCHANT_ID=your_wechat_merchant_id

# ==========================================
# 功能开关
# ==========================================
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false
VITE_ENABLE_PAYMENT=false
VITE_ENABLE_LOCATION_TRACKING=false

# ==========================================
# 环境
# ==========================================
VITE_ENV=development
