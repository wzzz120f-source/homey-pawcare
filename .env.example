# ==========================================
# Lovable Cloud / Supabase 配置（必填）
# 启用 Cloud 后由平台自动注入；自托管时手动填入。
# ==========================================
VITE_SUPABASE_PROJECT_ID=your_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# ==========================================
# 应用基本信息
# ==========================================
VITE_APP_NAME=萌宠到家
VITE_APP_VERSION=0.1.0
VITE_API_TIMEOUT=30000

# ==========================================
# 第三方服务
# 高德地图 JS API key（必填，用于地址、路线、定位）
# 申请：https://console.amap.com/dev/key/app
# ==========================================
VITE_AMAP_API_KEY=your_amap_js_api_key

# 支付（占位，未启用）
VITE_ALIPAY_APP_ID=
VITE_WECHAT_PAY_MERCHANT_ID=

# ==========================================
# 功能开关（可选）
# ==========================================
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false
VITE_ENABLE_PAYMENT=false
VITE_ENABLE_LOCATION_TRACKING=false

# ==========================================
# 部署所需的服务端 secrets（仅在 Cloud 控制台 / Supabase Functions 配置）
# 以下变量不应放入前端 .env：
#   LOVABLE_API_KEY     —— Lovable AI 网关
#   AMAP_API_KEY        —— 服务端高德 API
#   AMAP_SECURITY_KEY   —— 高德安全密钥
# ==========================================
VITE_ENV=development
